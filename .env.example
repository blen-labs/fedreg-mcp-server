# Transport — pick via CLI flag (default: stdio)
#   fedreg-mcp-server            # stdio
#   fedreg-mcp-server --http     # Streamable HTTP
PORT=8080
HOST=0.0.0.0
FEDREG_LOG_LEVEL=info                # debug | info | warn | error

# Sandbox
FEDREG_SANDBOX=auto                  # auto | isolate | deno
FEDREG_EXEC_TIMEOUT_MS=15000
FEDREG_EXEC_MEMORY_MB=64

# Upstream
FEDREG_FR_BASE_URL=https://www.federalregister.gov/api/v1
FEDREG_ECFR_BASE_URL=https://www.ecfr.gov/api
# Identify yourself per FederalRegister.gov / eCFR etiquette.
FEDREG_USER_AGENT=fedreg-mcp-server/0.1 (+https://github.com/blencorp/fedreg-mcp-server)
FEDREG_UPSTREAM_TIMEOUT_MS=20000
FEDREG_UPSTREAM_RETRIES=3

# Cache
FEDREG_CACHE_TTL_MS=300000
FEDREG_CACHE_MAX_ITEMS=2000

# ─── HTTP transport ─────────────────────────────────────────────────────────
# Set this to the public origin that clients reach (used in OAuth resource
# metadata and the WWW-Authenticate header).
FEDREG_PUBLIC_ORIGIN=https://your-host.example.com
# Comma-separated Host header allowlist (DNS-rebinding protection).
# Leave unset to disable (NOT recommended in production).
FEDREG_ALLOWED_HOSTS=your-host.example.com

# Rate limiting (per IP token bucket)
FEDREG_IP_RPS=5
FEDREG_IP_BURST=20
FEDREG_MAX_SESSIONS=500
# Per authenticated subject, requests per UTC day
FEDREG_SUBJECT_DAILY_QUOTA=10000

# ─── Auth ────────────────────────────────────────────────────────────────────
# none      - no auth (combine with --insecure for HTTP)
# embedded  - HS256 dev minter (DEV ONLY)
# generic-oidc / clerk / workos / auth0 - JWKS bearer verification via jose
FEDREG_AUTH_PROVIDER=none
FEDREG_AUTH_ISSUER=
FEDREG_AUTH_AUDIENCE=
FEDREG_AUTH_JWKS_URL=
FEDREG_AUTH_RESOURCE=
# Comma-separated scopes advertised in resource metadata.
FEDREG_AUTH_SCOPES=
